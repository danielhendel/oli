# ----------------------------------------
# Oli — Environment Template (STAGING ONLY)
# ----------------------------------------

# App environment
EXPO_PUBLIC_APP_ENV=staging

# ----------------------------------------
# Firebase (STAGING)
# Values come from Firebase Console → Web App
# ----------------------------------------
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=oli-staging-fdbba
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# ----------------------------------------
# Nutrition — Cloud Run API only (never EXPO_PUBLIC_*)
# Mobile calls GET /users/me/nutrition/* ; Nutritionix keys stay server-side.
# Local default: dev catalog. Staging/prod: hybrid uses Nutritionix when creds exist.
# ----------------------------------------
# NUTRITION_FOOD_PROVIDER=dev
# NUTRITIONIX_APP_ID=
# NUTRITIONIX_APP_KEY=
# NUTRITIONIX_REMOTE_USER_ID=0
# Set to 1 only for local debugging without Firestore graph writes:
# NUTRITION_FOOD_GRAPH_DISABLED=1

# ----------------------------------------
# Backend API (STAGING — use API Gateway URL for mobile)
# ----------------------------------------
# DO NOT use localhost
# Prefer the managed gateway host (*.uc.gateway.dev) — must match infra/gateway/openapi.yaml deploy.
EXPO_PUBLIC_BACKEND_BASE_URL=https://<your-gateway-host>.uc.gateway.dev
# Required when BACKEND_BASE_URL is a *.uc.gateway.dev host (consumer API key on query param ?key=)
EXPO_PUBLIC_GATEWAY_API_KEY=

# Optional client feature toggles (non-secret; baked into the JS bundle at Metro/EAS
# build or update time — changing them requires a new native/dev-client reload or a
# new EAS Update / app binary that embeds the value. Not a remote server kill switch.)
# EXPO_PUBLIC_DASH_WEEKLY_PROGRESS_RELOCATION=1
#   Dash Phase 1 — Weekly Progress relocation.
#   unset or "1" → enabled: Weekly Progress mounted under Program; absent from Dash.
#   "0"          → rollback: legacy Weekly Fitness mounted under Dash; absent from Program.
#   Any other value behaves as enabled (same as unset/"1").
#
# EXPO_PUBLIC_DASH_DAILY_MONITOR_FOUNDATION=1
#   Dash Phase 2C — Daily Monitor foundation.
#   unset or "1" → enabled candidate (Daily Monitor only when Weekly Progress relocation is also enabled).
#   "0"          → rollback: legacy Dash presentation (post–Phase 1 or full legacy depending on relocation).
#   Any other value behaves as enabled (same as unset/"1").
#   When Daily Monitor is ON and Weekly Progress relocation is OFF, the app falls back to legacy Dash
#   (no Daily Monitor + Weekly Fitness hybrid). Non-secret; baked into the JS bundle — not a remote kill switch.
#
# EXPO_PUBLIC_SLEEP_DURATION_DETAIL_V1=1
#   Dash Phase 2D — Sleep Duration detail pilot.
#   unset or "1" → enabled: Duration row opens the enriched Duration detail sheet (reference range + 7d/30d).
#   "0"          → rollback: Duration opens the legacy MetricDetailsSheet explainer.
#   Any other value behaves as enabled (same as unset/"1").
#   Only the Duration metric uses the new experience; other Sleep rows stay on the legacy sheet.
#   Non-secret; baked into the JS bundle — requires Metro reload / EAS Update / binary to change.

# Optional dev-only diagnostics (never enable in production builds you ship)
# EXPO_PUBLIC_DEBUG_API_BASE_URL=1   # logs EXPO_PUBLIC_BACKEND_BASE_URL once per authed request
# EXPO_PUBLIC_DEBUG_DATA_LOGS=1      # high-volume per-day cache/rollup diagnostics (dev only)
# EXPO_PUBLIC_NET_TRACE=1            # verbose [NET_TRACE] on success (default: failures/non-2xx only)
